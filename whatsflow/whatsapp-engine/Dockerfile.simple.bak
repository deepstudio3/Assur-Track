# Version simplifiée du moteur WhatsApp pour test
FROM node:18-alpine

WORKDIR /app

# Créer un simple serveur de test inline
RUN cat > simple-server.js << 'EOF'
const http = require("http");
const server = http.createServer((req, res) => {
    res.writeHead(200, {"Content-Type": "application/json"});
    if (req.url === "/health") {
        res.end(JSON.stringify({
            status: "healthy", 
            port: process.env.PORT || 3010,
            session_id: process.env.SESSION_ID || "unknown"
        }));
    } else if (req.url === "/qr") {
        // QR code de test (200x200 pixels) - pas 1x1 !
        res.end(JSON.stringify({
            qr: "data:image/png;base64,iVBORw0KGgoAAAANSUhEUgAAAMgAAADICAYAAACtWK6eAAAABHNCSVQICAgIfAhkiAAAAAlwSFlzAAALEgAACxIB0t1+/AAAABx0RVh0U29mdHdhcmUAQWRvYmUgRmlyZXdvcmtzIENTNui8sowAAAAWdEVYdENyZWF0aW9uIFRpbWUAMDcvMTUvMTTowM+o6AAAADUlEQVR42mNkYPhfDwAChwGA60e6kgAAAABJRU5ErkJggg=="
        }));
    } else if (req.url === "/status") {
        res.end(JSON.stringify({
            status: "awaiting_login",
            connected: false,
            session_id: process.env.SESSION_ID || "unknown"
        }));
    } else {
        res.end(JSON.stringify({status: "ok", service: "whatsapp-engine"}));
    }
});

server.listen(process.env.PORT || 3010, "0.0.0.0");
console.log(`WhatsApp Engine running on port ${process.env.PORT || 3010}`);
EOF

EXPOSE 3010

CMD ["node", "simple-server.js"]
