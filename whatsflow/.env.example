# Database Configuration
POSTGRES_USER=whatsflow
POSTGRES_PASSWORD=whatsflow_secure_password
POSTGRES_DB=whatsflow
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://whatsflow:whatsflow_secure_password@postgres:5432/whatsflow

# Redis Configuration
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_BASE_URL=http://localhost:8000
ENVIRONMENT=development

# Security
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24
API_KEY_LENGTH=32

# WhatsApp / OpenWA Configuration
OPENWA_PORT=3000
SESSION_TIMEOUT_MINUTES=30
MAX_SESSIONS_PER_CLIENT=5
MAX_CLIENTS=502

# Rate Limiting
RATE_LIMIT_MESSAGES_PER_SECOND=1
RATE_LIMIT_API_REQUESTS_PER_MINUTE=60

# Monitoring
ENABLE_METRICS=true
LOG_LEVEL=INFO
