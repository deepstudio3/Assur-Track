# --- Backend ---
NODE_ENV=development
PORT=4000

# Base de données (PostgreSQL)
DATABASE_URL=postgresql://assurtrack_user:assurtrack_secret_2026@localhost:5432/assurtrack

# Authentification
JWT_SECRET=change-this-in-production
JWT_EXPIRES_IN=12h

# CORS — origine autorisée du frontend
CORS_ORIGIN=http://localhost:5173

# --- WhatsApp (WhatsFlow) ---
# Laisser WHATSFLOW_URL vide pour désactiver complètement WhatsApp.
# En Docker, l'API WhatsFlow est jointe sur http://whatsflow-api:8000
# En local hors Docker : http://localhost:8001
# API_KEY / CLIENT_ID : créés une fois via le client WhatsFlow
#   (POST /api/clients/ — voir whatsflow/create_client.ps1) puis collés ici.
WHATSFLOW_URL=
WHATSFLOW_API_KEY=
WHATSFLOW_CLIENT_ID=

# Cron des relances (fuseau de Douala)
RELANCES_CRON=0 7 * * *
RELANCES_TZ=Africa/Douala
