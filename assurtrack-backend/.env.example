# --- Backend ---
NODE_ENV=development
PORT=4000

# Base de données (PostgreSQL)
DATABASE_URL=postgresql://assurtrack_user:assurtrack_secret_2026@localhost:5432/assurtrack

# Authentification
JWT_SECRET=change-this-in-production
JWT_EXPIRES_IN=12h

# CORS — origine autorisée du frontend
CORS_ORIGIN=http://localhost:5173

# --- WhatsApp / Swift AI (WhatsFlow) ---
# Laisser WHATSFLOW_URL vide pour désactiver les envois (mode étape 2/3 sans WhatsApp)
WHATSFLOW_URL=
WHATSFLOW_TOKEN=whatsflow-internal-2026
WHATSFLOW_CLIENT=852ed5d0-25c6-4f0b-b942-6023a55c5ca4

# Cron des relances (fuseau de Douala)
RELANCES_CRON=0 7 * * *
RELANCES_TZ=Africa/Douala
