# Variables consommées par docker-compose.yml (racine).
# Copier en .env puis renseigner si besoin : cp .env.example .env

# URL de l'infrastructure WhatsApp (Swift AI / WhatsFlow).
# Laisser vide pour démarrer sans WhatsApp (les envois sont alors ignorés).
# Depuis un conteneur, pour joindre un service sur la machine hôte :
#   WHATSFLOW_URL=http://host.docker.internal:3001
WHATSFLOW_URL=
