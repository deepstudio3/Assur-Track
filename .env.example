# Variables consommées par docker-compose.yml (racine).
# Copier en .env puis renseigner : cp .env.example .env

# --- WhatsApp (WhatsFlow) ---
# Créez une fois un client WhatsFlow (après que la stack tourne) :
#   POST http://localhost:8011/api/clients/  (stack AssurTrack ; 8001 = Swift AI)
# La réponse fournit api_key + id : collez-les ci-dessous puis
#   docker compose up -d backend   (pour recharger l'API AssurTrack).
# Laisser vide = WhatsApp désactivé (l'app fonctionne, les envois sont ignorés).
WHATSFLOW_API_KEY=
WHATSFLOW_CLIENT_ID=
