# ============================================================
#  AssurTrack — variables de PRODUCTION
#  Sur le serveur :  cp .env.prod.example .env   puis remplir.
#  NE JAMAIS committer le fichier .env rempli (il est dans .gitignore).
#  Astuce génération de secret :  openssl rand -hex 32
# ============================================================

# URL publique de l'application (SANS slash final)
PUBLIC_URL=https://kamillendi.com

# --- Base de données AssurTrack ---
POSTGRES_DB=assurtrack
POSTGRES_USER=assurtrack_user
POSTGRES_PASSWORD=CHANGER_MOI_mot_de_passe_db_fort

# --- Sécurité backend ---
JWT_SECRET=CHANGER_MOI_secret_jwt_64_caracteres
JWT_EXPIRES_IN=12h

# --- Compte patronne initial (créé au 1er démarrage, sans données de démo) ---
ADMIN_EMAIL=patronne@kamillendi.com
ADMIN_PASSWORD=CHANGER_MOI_mot_de_passe_initial
ADMIN_NOM=Ndongo
ADMIN_PRENOM=Henriette
ADMIN_TEL_WA=+237682731274
# Informations de l'entreprise
ENTREPRISE_NOM=Mon Entreprise d'Assurance
ENTREPRISE_TEL_GERANT=
ENTREPRISE_TEL_RESPONSABLE=

# --- Relances (cron quotidien des échéances) ---
RELANCES_CRON=0 7 * * *
RELANCES_TZ=Africa/Douala

# --- WhatsApp (WhatsFlow) ---
# À remplir APRÈS avoir créé le client WhatsFlow (voir DEPLOYMENT.md, étape 6).
# Laisser vide = WhatsApp désactivé (l'app fonctionne, les envois sont ignorés).
WHATSFLOW_API_KEY=
WHATSFLOW_CLIENT_ID=

# --- WhatsFlow (infrastructure interne) ---
WHATSFLOW_DB_PASSWORD=CHANGER_MOI_mot_de_passe_whatsflow_db
WHATSFLOW_JWT_SECRET=CHANGER_MOI_secret_jwt_whatsflow
WHATSFLOW_INTERNAL_TOKEN=CHANGER_MOI_token_interne_whatsflow
